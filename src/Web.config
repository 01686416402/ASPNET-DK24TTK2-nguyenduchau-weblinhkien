<?xml version="1.0"?>
<configuration>
  <!-- ===== DATABASE ===== -->
  <connectionStrings>
    <add name="conn" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=DBLinhKien;Integrated Security=True" providerName="System.Data.SqlClient"/>
  </connectionStrings>
  <!-- ===== ASP.NET ===== -->
  <system.web>
    <!-- ⚡ TẮT DEBUG (nhẹ + chuẩn nộp) -->
    <compilation debug="true" targetFramework="4.7.2"/>
    <httpRuntime targetFramework="4.7.2"/>
    <!-- ⚠️ CHO PHÉP POST DATA (form) -->
    <pages validateRequest="false"/>
  </system.web>
  <!-- ===== FIX PACKAGE CONFLICT ===== -->
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- ✅ JSON (GIỮ) -->
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" culture="neutral" publicKeyToken="30ad4fe6b2a6aeed"/>
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>